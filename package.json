{
  "name": "dersloop",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build:desktop --workspace=apps/desktop",
    "db:generate": "npm run generate --workspace=packages/database",
    "db:migrate": "npm run migrate --workspace=packages/database",
    "db:seed": "npm run seed --workspace=packages/database",
    "db:push": "npm run push --workspace=packages/database",
    "postinstall": "npm run db:generate"
  },
  "engines": {
    "node": ">=18"
  }
}
